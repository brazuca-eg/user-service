# user-service — prod env (set in the platform dashboard)
SPRING_PROFILES_ACTIVE=prod

# Supabase Postgres
DB_URL=jdbc:postgresql://<host>:6543/postgres?currentSchema=user_svc
DB_USERNAME=
DB_PASSWORD=
DB_POOL_SIZE=5

# RSA signing keys as PEM contents
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# CORS — the public SPA origin (Vercel)
CORS_ALLOWED_ORIGINS=https://<app>.vercel.app

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75
